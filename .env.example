# Copy to .env.local for local dev. Set the SAME vars in Vercel
# (Project Settings -> Environment Variables, for Production + Preview).
#
# Values come from Supabase: Project Settings -> Data API / API Keys.
# Only the ANON (publishable) key belongs in the browser. Never put the
# service-role/secret key here or in any VITE_ var.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
